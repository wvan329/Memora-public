# 工作目录（所有文件操作在此目录下进行）
WORK_DIR=D:\work

# 共享目录（skill 等公共资源）
SHARED_DIR=shared

# AI 配置
MODEL_NAME="deepseek-v4-pro"
BASE_URL="https://api.deepseek.com"
API_KEY=你的API_KEY
ALI_API_KEY=你的阿里云API_KEY（可选）
ALI_BAILIAN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
ALI_VISION_MODEL="qwen3.7-plus"

# 访问密码（WebSocket / HTTP 认证）
ACCESS_PASSWORD=你的访问密码

# 邮件通知（可选，任务完成后发送通知）
EMAIL_SMTP_SERVER=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_FROM=你的邮箱@qq.com
EMAIL_PASSWORD=你的邮箱授权码
EMAIL_TO=你的邮箱@qq.com

# SSH 远程服务器凭据（可选）
SSH_HOST=你的服务器地址
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=你的SSH密码

# 阿里云 ECS API（可选，重启服务器等）
ALI_ACCESS_KEY_ID=你的ALI_ACCESS_KEY_ID
ALI_ACCESS_KEY_SECRET=你的ALI_ACCESS_KEY_SECRET
ALI_ECS_REGION=cn-beijing
ALI_ECS_INSTANCE_ID=你的ECS实例ID
NOTIFICATION_ENABLED=false
VISION_HIGH_RES_DEFAULT=true

# 高德地图 API Key（可选，地图相关功能）
AMAP_API_KEY=你的高德地图API_KEY
BROWSER_HEADED=true
